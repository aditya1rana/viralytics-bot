{
  "name": "viralytics-bot",
  "version": "1.0.0",
  "description": "Production-ready Discord bot for Viralytics clipping agency",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "prisma generate && npm run build:dashboard && tsc",
    "build:dashboard": "cd dashboard && npm install --include=dev && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "deploy-commands": "tsx src/scripts/deployCommands.ts",
    "seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "cors": "^2.8.6",
    "cron": "^3.5.0",
    "csv-writer": "^1.6.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "ioredis": "^5.6.1",
    "nanoid": "^5.1.5",
    "winston": "^3.17.0",
    "zod": "^3.25.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=20.0.0"
  }
}
